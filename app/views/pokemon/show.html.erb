<div class="row">
  <div class="col-md-4 text-center">
    <div class="card mb-4">
      <div class="card-body">
        <!-- ERB -->
        <%= image_tag @pokemon.sprite_url,
            class: "img-fluid mb-3",
            style: "max-height: 250px;",
            alt: @pokemon.name %>

        <h2><%= @pokemon.name %></h2>

        <p class="text-muted">
          <!-- ERB -->
          #<%= @pokemon.pokedex_number.to_s.rjust(3, "0") %>
        </p>

      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card mb-4">
      <div class="card-body">

        <h3>Pokemon Information</h3>

        <!-- Using basic Bootstrap table striped -->
        <table class="table table-striped">

          <tr>
            <th>Height</th>
            <!-- ERB -->
            <td><%= @pokemon.height %></td>
          </tr>

          <tr>
            <th>Weight</th>
            <!-- ERB -->
            <td><%= @pokemon.weight %></td>
          </tr>

          <tr>
            <th>Base Experience</th>
            <!-- ERB -->
            <td><%= @pokemon.base_experience %></td>
          </tr>

          <tr>
            <th>Types</th>
            <td>
              <% @pokemon.types.each do |type| %>
                <span class="badge bg-secondary"><%= type.name %></span>
              <% end %>
            </td>
          </tr>

        </table>

      </div>
    </div>

    <div class="card">
      <div class="card-body">

        <h3>User Reviews</h3>

        <% @pokemon.reviews.each do |review| %>

          <!-- Creates a bottom border between each review -->
          <div class="border-bottom mb-3 pb-3">

            <!-- ERB -->
            <strong><%= review.username %></strong>

            <!-- Bootstrap badge with yellow background -->
            <span class="badge bg-warning text-dark">
              <!-- ERB -->
              <%= review.rating %>/5
            </span>

            <p class="mt-2">
              <!-- ERB -->
              <%= review.comment %>
            </p>

          </div>
        <% end %>
      </div>
    </div>
    <!-- ERB -->
    <%= link_to "← Back to Pokemon", pokemon_index_path, class: "btn btn-danger mt-3" %>
  </div>
</div>