<div class="row">
  <div class="col-md-4 text-center">
    <div class="card mb-4">
      <div class="card-body">
        <%= image_tag @pokemon.sprite_url,
            class: "img-fluid mb-3",
            style: "max-height: 250px;",
            alt: @pokemon.name %>

        <h2><%= @pokemon.name %></h2>

        <p class="text-muted">
          #<%= @pokemon.pokedex_number.to_s.rjust(3, "0") %>
        </p>

      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card mb-4">
      <div class="card-body">

        <h3>Pokemon Information</h3>

        <!-- Using basic Bootstrap table striped -->
        <table class="table table-striped">

          <tr>
            <th>Height</th>
            <td><%= @pokemon.height %></td>
          </tr>

          <tr>
            <th>Weight</th>
            <td><%= @pokemon.weight %></td>
          </tr>

          <tr>
            <th>Base Experience</th>
            <td><%= @pokemon.base_experience %></td>
          </tr>

          <tr>
            <th>Types</th>
            <td>
              <% @pokemon.types.each do |type| %>
                <span class="badge bg-secondary"><%= type.name %></span>
              <% end %>
            </td>
          </tr>

        </table>

      </div>
    </div>

    <div class="card">
      <div class="card-body">

        <h3>User Reviews</h3>

          <!-- Feature 5.2 - ERB Conditional -->
          <!-- Displays all reviews if they exist; otherwise shows a message -->
          <!-- Check if this Pokemon has any reviews -->
          <% if @pokemon.reviews.any? %>
            <!-- Loop through each review and display it -->
            <% @pokemon.reviews.each do |review| %>

              <div class="border-bottom mb-3 pb-3">

                <strong><%= review.username %></strong>

                <span class="badge bg-warning text-dark">
                  <%= review.rating %>/5
                </span>

                <p class="mt-2">
                  <%= review.comment %>
                </p>

              </div>

            <% end %>
          <% else %>

          <!-- Display this message if there are no reviews -->
          <p class="text-muted">No reviews have been added for this Pokémon.</p>

        <% end %>
      </div>
    </div>
    <%= link_to "← Back to Pokemon", pokemon_index_path, class: "btn btn-danger mt-3" %>
  </div>
</div>