<!-- Feature 3.1 - Collection Navigation -->
<!-- Displays the full Pokemon collection allowing users to browse all imported Pokemon -->
<!-- Feature 3.4 - Hierarchical Collection Navigation -->
<!-- Allows users to browse Pokemon by their associated Type -->

<h1 class="mb-4">Pokemon Types</h1>

<div class="row g-4">
  <% @types.each do |type| %>
    <div class="col-sm-6 col-md-4 col-lg-3">
      <div class="card text-center h-100">
        <div class="card-body">

          <h2 class="h5 card-title"><%= type.name %></h2>

          <p class="text-muted">
            <%= type.pokemon.count %> Pokemon
          </p>

          <%= link_to "View #{type.name} Pokemon",
              type_path(type),
              class: "btn btn-danger" %>

        </div>
      </div>
    </div>
  <% end %>
</div>